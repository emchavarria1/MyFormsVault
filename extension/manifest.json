{
  "manifest_version": 3,
  "name": "MyFormsVault",
  "version": "0.1.0",
  "description": "Your personal information, reusable everywhere — without selling your data.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "MyFormsVault",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
